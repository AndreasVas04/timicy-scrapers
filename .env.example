# Copy this file to .env and fill in your real values locally.
# .env is gitignored — never commit real credentials. Placeholders only here.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres

# Residential proxy pool (stephanis — Cloudflare IP-based block)
SCRAPER_PROXY_HOST=isp.decodo.com
SCRAPER_PROXY_USER=YOUR_PROXY_USERNAME
SCRAPER_PROXY_PASS=YOUR_PROXY_PASSWORD
SCRAPER_PROXY_PORTS=10001,10002,10003
